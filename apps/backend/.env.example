TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development

# MODE = local (HTTP fetch worker direct) | queue (publish ActiveMQ, KEDA spawns worker Job)
MODE=local
WORKER_URL=http://127.0.0.1:3001

# queue mode (Phase 3)
ARTEMIS_HOST=127.0.0.1
ARTEMIS_PORT=61613
ARTEMIS_USER=artemis
ARTEMIS_PASSWORD=artemis
QUEUE_IN=world-gen
QUEUE_OUT=world-done